{% extends 'base-super_admin.html.twig' %}

{% block header %}
    {{ 'adm.evenement.show.heading'|trans({}, 'evenement') }}
{% endblock %}

{% block headeractions %}
    <div class="header-action d-flex gap-2">
        {{ include('composants/sadm-buttons-show.html.twig', {elt: 'evenement', id: evenement.id}) }}
    </div>
{% endblock %}

{% block content %}
    <div class="card">
        <h4 class="card-title">{{ 'adm.evenement.show.heading'|trans({}, 'evenement') }}</h4>
        <div class="card-body">
            <table class="table">
                <tbody>
                <tr>
                    <th>{{ 'table.id'|trans }}</th>
                    <td>{{ evenement.id }}</td>
                </tr>
                <tr>
                    <th>{{ 'table.libelle'|trans }}</th>
                    <td>{{ evenement.libelle }}</td>
                </tr>
                <tr>
                    <th>{{ 'table.date'|trans }}</th>
                    <td>{{ evenement.date ? evenement.date|format_date('long') : '' }}</td>
                </tr>
                <tr>
                    <th>{{ 'table.heure_debut'|trans }}</th>
                    <td>{{ evenement.debut ? evenement.debut|date('H:i') : '' }}</td>
                </tr>
                <tr>
                    <th>{{ 'table.heure_fin'|trans }}</th>
                    <td>{{ evenement.fin ? evenement.fin|date('H:i') : '' }}</td>
                </tr>
                <tr>
                    <th>{{ 'table.adresse'|trans }}</th>
                    <td>
                        {{ evenement.adresse.adresse1 }}
                        {{ evenement.adresse.adresse2 }}
                        {{ evenement.adresse.adresse3 }}
                        {{ evenement.adresse.codePostal }}
                        {{ evenement.adresse.ville }}
                        {{ evenement.adresse.pays }}
                    </td>
                </tr>
                <tr>
                    <th>{{ 'table.description'|trans }}</th>
                    <td>{{ evenement.description }}</td>
                </tr>
                <tr>
                    <th>{{ 'table.participants'|trans }}</th>
                    <td>{{ evenement.etudiantEvenements|length }}</td>
                </tr>
                </tbody>
            </table>

            <div class="d-flex align-items-center gap-2 mb-3">
                <h5>{{ 'adm.evenement.attendance'|trans({}, 'evenement') }}</h5>
                <a class="btn btn-sm btn-secondary"
                   href="{{ path('app_emargement_export', {id: evenement.id}) }}"
                   title="{{ 'adm.evenement.exporterresultxlsx'|trans({}, 'evenement') }}"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom">
                    <i class="fas fa-download"></i>
                </a>
            </div>

            {# Onglets par département #}
            {% if etudiantsParDepartement is not empty %}
                <ul class="nav nav-tabs mb-3" id="departementTabs" role="tablist">
                    {# Onglet "Tous" #}
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active"
                                id="tab-all"
                                data-bs-toggle="tab"
                                data-bs-target="#pane-all"
                                type="button"
                                role="tab"
                                aria-controls="pane-all"
                                aria-selected="true">
                            Tous
                            <span class="badge bg-secondary ms-1">{{ etudiantsEvenement|length }}</span>
                        </button>
                    </li>
                    {% for departement, data in etudiantsParDepartement %}
                        {% set tabId = 'tab-' ~ loop.index %}
                        {% set paneId = 'pane-' ~ loop.index %}
                        <li class="nav-item" role="presentation">
                            <button class="nav-link"
                                    id="{{ tabId }}"
                                    data-bs-toggle="tab"
                                    data-bs-target="#{{ paneId }}"
                                    type="button"
                                    role="tab"
                                    aria-controls="{{ paneId }}"
                                    aria-selected="false">
                                {{ departement }}
                                <span class="badge bg-secondary ms-1">{{ data.total }}</span>
                            </button>
                        </li>
                    {% endfor %}
                </ul>

                <div class="tab-content" id="departementTabsContent">
                    {# Panneau "Tous" #}
                    <div class="tab-pane fade show active"
                         id="pane-all"
                         role="tabpanel"
                         aria-labelledby="tab-all">
                        {% set totalPresents = 0 %}
                        {% for ee in etudiantsEvenement %}
                            {% if ee.present %}
                                {% set totalPresents = totalPresents + 1 %}
                            {% endif %}
                        {% endfor %}

                        <p class="mb-2">
                            <strong>Présences : </strong>
                            <span class="badge fs-6 bg-{% if totalPresents == etudiantsEvenement|length %}success{% elseif totalPresents == 0 %}danger{% else %}warning{% endif %}">
            {{ totalPresents }} / {{ etudiantsEvenement|length }}
        </span>
                        </p>
                        {{ _self.tableEmargement(etudiantsEvenement, evenement) }}
                    </div>

                    {% for departement, data in etudiantsParDepartement %}
                        {% set paneId = 'pane-' ~ loop.index %}
                        {% set tabId = 'tab-' ~ loop.index %}
                        <div class="tab-pane fade"
                             id="{{ paneId }}"
                             role="tabpanel"
                             aria-labelledby="{{ tabId }}">

                            <p class="mb-2">
                                <strong>Présences : </strong>
                                <span class="badge fs-6 bg-{% if data.presents == data.total %}success{% elseif data.presents == 0 %}danger{% else %}warning{% endif %}">
                {{ data.presents }} / {{ data.total }}
            </span>
                            </p>

                            {{ _self.tableEmargement(data.etudiants, evenement) }}
                        </div>
                    {% endfor %}

                </div>

            {% else %}
                <p class="text-muted">{{ 'table.empty'|trans }}</p>
            {% endif %}

        </div>
    </div>
{% endblock %}

{# Macro pour éviter la duplication du tableau d'émargement #}
{% macro tableEmargement(etudiants, evenement) %}
    <table class="table table-striped" data-xls-sheet="Émargement">
        <thead>
        <tr>
            <th>#</th>
            <th>{{ 'table.prenom'|trans }}</th>
            <th>{{ 'table.nom'|trans }}</th>
            <th>Semestre</th>
            <th>Présence</th>
            <th>Date signature</th>
            <th>Marquer présent</th>
        </tr>
        </thead>
        <tbody>
        {% for etudiantEvenement in etudiants %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ etudiantEvenement.etudiant.prenom }}</td>
                <td>{{ etudiantEvenement.etudiant.nom ?? '-' }}</td>
                <td>{{ etudiantEvenement.etudiant.semestreActif }}</td>
                <td>
                    {% if etudiantEvenement.present %}
                        <span class="badge bg-success">{{ 'oui'|trans }}</span>
                    {% else %}
                        <span class="badge bg-danger">{{ 'non'|trans }}</span>
                    {% endif %}
                </td>

                {# Vérification de cohérence de la date/heure de signature #}
                {% set sig = etudiantEvenement.dateSignature %}
                {% set danger = false %}
                {% if sig %}
                    {% set sigDate = sig|date('Y-m-d') %}
                    {% set eventDate = evenement.date ? evenement.date|date('Y-m-d') : '' %}
                    {% set timeChecksOk = true %}
                    {% if evenement.date and evenement.debut and evenement.fin %}
                        {% set startDt = date(eventDate ~ ' ' ~ (evenement.debut|date('H:i')) ~ ' -1 hour') %}
                        {% set endDt   = date(eventDate ~ ' ' ~ (evenement.fin|date('H:i'))   ~ ' +1 hour') %}
                        {% set timeChecksOk = (sig.timestamp >= startDt.timestamp) and (sig.timestamp <= endDt.timestamp) %}
                    {% endif %}
                    {% if sigDate != eventDate or not timeChecksOk %}
                        {% set danger = true %}
                    {% endif %}
                {% endif %}

                <td class="{{ danger ? 'text-danger' : '' }}">
                    {% if sig %}
                        {{ sig|date('d/m/Y H:i') }}
                    {% else %}
                        -
                    {% endif %}
                </td>
                <td>
                    <a class="btn btn-sm btn-primary {{ etudiantEvenement.present !== false ? 'disabled' }}"
                       href="{{ path('app_evenement_confirm_presence', {id: etudiantEvenement.id}) }}"
                       title="Marquer l'étudiant présent"
                       data-bs-toggle="tooltip"
                       data-bs-placement="bottom">
                        <i class="fas fa-check-circle"></i>
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">{{ 'table.empty'|trans }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endmacro %}
